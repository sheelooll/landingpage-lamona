# ============================================================
# .gitignore — Comercializadora La Mona
# Evita subir secretos y basura al repositorio (GitHub Pages).
# ============================================================

# Credenciales y secretos — NUNCA subir al repo
.env
.env.*
*.env
serviceAccountKey.json
firebase-adminsdk*.json
*service-account*.json
*-service-account.json
.firebase/
.runtimeconfig.json
*.pem
*.key

# Dependencias
node_modules/
package-lock.json

# Logs y caché de herramientas
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
.cache/

# Sistema operativo / editor
.DS_Store
Thumbs.db
*.swp
.idea/

# El directorio local de Claude (memoria/planes) no va al repo
.claude/
